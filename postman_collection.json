      "item": [
        {
          "name": "1. Create Offering",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teacherId\": \"bb1d0828-47e9-4b97-9587-927663f191a4\",\n  \"courseId\": \"412c4c20-48b1-4753-86f0-8f358f0ac594\",\n  \"name\": \"Saturday Python Batch\",\n  \"capacity\": 5\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/teachers/offerings",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "teachers",
                "offerings"
              ]
            },
            "description": "Creates a new class offering section with a student capacity limit."
          },
          "response": []
        },
        {
          "name": "2. Add Sessions to Offering",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teacherId\": \"bb1d0828-47e9-4b97-9587-927663f191a4\",\n  \"timezone\": \"Asia/Kolkata\",\n  \"sessions\": [\n    {\n      \"startTime\": \"2026-06-06 18:00:00\",\n      \"endTime\": \"2026-06-06 19:00:00\"\n    },\n    {\n      \"startTime\": \"2026-06-13 18:00:00\",\n      \"endTime\": \"2026-06-13 19:00:00\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/teachers/offerings/REPLACE_WITH_OFFERING_ID/sessions",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "teachers",
                "offerings",
                "REPLACE_WITH_OFFERING_ID",
                "sessions"
              ]
            },
            "description": "Schedules date/time sessions for a class offering. Converts input local times to UTC."
          },
          "response": []
        },
        {
          "name": "3. Get Teacher Offerings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/teachers/bb1d0828-47e9-4b97-9587-927663f191a4/offerings",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "teachers",
                "bb1d0828-47e9-4b97-9587-927663f191a4",
                "offerings"
              ]
            },
            "description": "Retrieves all offerings, scheduled sessions, and booking stats for a specific teacher."
          },
          "response": []
        }
      ]
    },
    {
